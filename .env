# Loaded automatically by Vite on `npm run dev` / `npm run build`.
# Mirrors the values docker-compose.yml + entry-point.sh inject when running
# in Docker, so the two run paths target the same staging backends.

VITE_API_URL=https://verifierapi.openid4vc.staging.yivi.app
VITE_VERAMO_API_URL=https://veramo-verifier.openid4vc.staging.yivi.app
VITE_VERAMO_VERIFIER_NAME=test-verifier
VITE_VERAMO_ADMIN_TOKEN=veramo-verifier-admin-token
VITE_IRMA_SERVER_URL=https://is.demo.staging.yivi.app
