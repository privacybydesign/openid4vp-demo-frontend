# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must never be committed. Vite loads these automatically on `npm run dev` /
# `npm run build`; docker-compose.yml + entry-point.sh inject the same values
# (without the VITE_ prefix) when running in Docker.

VITE_API_URL=https://verifierapi.openid4vc.staging.yivi.app
VITE_VERAMO_API_URL=https://veramo-verifier.openid4vc.staging.yivi.app
VITE_VERAMO_VERIFIER_NAME=test-verifier

# Admin tokens — REQUIRED, no default. Obtain from a maintainer; do not commit.
VITE_VERAMO_ADMIN_TOKEN=your-veramo-verifier-admin-token
VITE_VERAMO_ISSUER_ADMIN_TOKEN=your-veramo-issuer-admin-token

VITE_IRMA_SERVER_URL=https://is.demo.staging.yivi.app
VITE_UNIVERSAL_LINK_HOST=open.yivi.app
